{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/evidence.v1.schema.json",
  "title": "Toolab Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "scenario_fingerprint",
    "execution",
    "stats",
    "outcomes",
    "samples",
    "assertions",
    "unknowns",
    "redaction_summary",
    "repro",
    "deterministic_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolab_version", "mode", "run_id", "run_seed", "chaos_seed"],
      "properties": {
        "toolab_version": { "type": "string" },
        "mode": { "type": "string", "const": "black" },
        "run_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "run_seed": { "type": "string", "pattern": "^[0-9]{1,20}$" },
        "chaos_seed": { "type": "string", "pattern": "^[0-9]{1,20}$" },
        "started_utc": { "type": "string", "format": "date-time" },
        "finished_utc": { "type": "string", "format": "date-time" },
        "db_seed_reference": { "type": "string" }
      }
    },
    "scenario_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_path", "scenario_sha256", "scenario_schema_version"],
      "properties": {
        "scenario_path": { "type": "string" },
        "scenario_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "scenario_schema_version": { "type": "integer", "const": 1 }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schedule_mode",
        "concurrency",
        "duration_s",
        "planned_requests",
        "completed_requests",
        "decision_engine_version",
        "decision_tape_hash"
      ],
      "properties": {
        "schedule_mode": { "type": "string", "enum": ["closed_loop", "open_loop"] },
        "tick_ms": { "type": "integer", "minimum": 1 },
        "concurrency": { "type": "integer", "minimum": 1 },
        "duration_s": { "type": "integer", "minimum": 1 },
        "planned_requests": { "type": "integer", "minimum": 0 },
        "completed_requests": { "type": "integer", "minimum": 0 },
        "decision_engine_version": { "type": "string" },
        "decision_tape_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_requests", "success_rate", "error_rate", "p50_ms", "p95_ms", "p99_ms", "status_histogram"],
      "properties": {
        "total_requests": { "type": "integer", "minimum": 0 },
        "success_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "p50_ms": { "type": "integer", "minimum": 0 },
        "p95_ms": { "type": "integer", "minimum": 0 },
        "p99_ms": { "type": "integer", "minimum": 0 },
        "status_histogram": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "request_id", "method", "path", "error_kind", "latency_ms", "response_hash", "chaos_applied"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "request_id": { "type": "string" },
          "method": { "type": "string" },
          "path": { "type": "string" },
          "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
          "error_kind": {
            "type": "string",
            "enum": ["none", "timeout", "dns", "tls", "conn", "read", "chaos_abort", "http_status_error"]
          },
          "latency_ms": { "type": "integer", "minimum": 0 },
          "response_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "chaos_applied": {
            "type": "object",
            "additionalProperties": false,
            "required": ["latency_injected_ms", "error_injected", "error_mode", "payload_drift_applied", "payload_mutations"],
            "properties": {
              "latency_injected_ms": { "type": "integer", "minimum": 0 },
              "error_injected": { "type": "boolean" },
              "error_mode": { "type": "string", "const": "abort" },
              "payload_drift_applied": { "type": "boolean" },
              "payload_mutations": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "request", "response"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "request": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "url", "headers", "body_preview", "body_sha256", "redacted"],
            "properties": {
              "method": { "type": "string" },
              "url": { "type": "string" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body_preview": { "type": "string", "maxLength": 4096 },
              "body_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "redacted": { "type": "boolean" }
            }
          },
          "response": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status_code", "error_kind", "headers", "body_preview", "body_sha256", "redacted"],
            "properties": {
              "status_code": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
              "error_kind": { "type": "string" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body_preview": { "type": "string", "maxLength": 4096 },
              "body_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "redacted": { "type": "boolean" }
            }
          }
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics_snapshot": { "type": "object" },
        "trace_refs": { "type": "array", "items": { "type": "string" } },
        "logs_excerpt": {
          "type": "array",
          "maxItems": 500,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["timestamp", "level", "message"],
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "level": { "type": "string" },
              "message": { "type": "string" },
              "attrs": { "type": "object" }
            }
          }
        }
      }
    },
    "assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "rules", "violated_rules"],
      "properties": {
        "overall": { "type": "string", "enum": ["PASS", "FAIL"] },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "passed", "observed", "expected", "message"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "passed": { "type": "boolean" },
              "observed": {},
              "expected": {},
              "message": { "type": "string" }
            }
          }
        },
        "violated_rules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "unknowns": { "type": "array", "items": { "type": "string" } },
    "redaction_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headers_redacted", "json_paths_redacted", "mask", "max_body_preview_bytes", "max_samples"],
      "properties": {
        "headers_redacted": { "type": "array", "items": { "type": "string" } },
        "json_paths_redacted": { "type": "array", "items": { "type": "string" } },
        "mask": { "type": "string" },
        "max_body_preview_bytes": { "type": "integer", "minimum": 1 },
        "max_samples": { "type": "integer", "minimum": 1, "maximum": 200 }
      }
    },
    "repro": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "script_path", "expected_deterministic_fingerprint"],
      "properties": {
        "command": { "type": "string" },
        "script_path": { "type": "string" },
        "expected_deterministic_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "go_version": { "type": "string" },
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "http_client": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "timeout_ms_default": { "type": "integer", "minimum": 1 },
            "redirects": { "type": "string", "enum": ["disabled"] }
          }
        }
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
