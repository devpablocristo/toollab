{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/scenario.v1.schema.json",
  "title": "Toolab Scenario v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode", "target", "workload", "chaos", "expectations", "seeds"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "mode": { "type": "string", "const": "black" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url", "headers", "auth"],
      "properties": {
        "base_url": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "auth": { "$ref": "#/$defs/auth" }
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "concurrency", "duration_s", "schedule_mode"],
      "properties": {
        "requests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/requestSpec" }
        },
        "concurrency": { "type": "integer", "minimum": 1 },
        "duration_s": { "type": "integer", "minimum": 1 },
        "schedule_mode": { "type": "string", "enum": ["closed_loop", "open_loop"] },
        "tick_ms": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "schedule_mode": { "const": "open_loop" } },
            "required": ["schedule_mode"]
          },
          "then": { "required": ["tick_ms"] }
        }
      ]
    },
    "chaos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["latency", "error_rate", "error_statuses", "error_mode"],
      "properties": {
        "latency": { "$ref": "#/$defs/latency" },
        "error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "error_statuses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 400, "maximum": 599 },
          "uniqueItems": true
        },
        "error_mode": { "type": "string", "const": "abort" },
        "flapping": { "$ref": "#/$defs/flapping" },
        "payload_drift": { "$ref": "#/$defs/payloadDrift" }
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_error_rate", "max_p95_ms", "invariants"],
      "properties": {
        "max_error_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_p95_ms": { "type": "integer", "minimum": 1 },
        "invariants": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/invariant" }
        }
      }
    },
    "seeds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_seed", "chaos_seed"],
      "properties": {
        "run_seed": { "$ref": "#/$defs/seed" },
        "chaos_seed": { "$ref": "#/$defs/seed" },
        "db_seed_reference": { "type": "string", "minLength": 1 }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["endpoint", "scrape_at"],
          "properties": {
            "endpoint": { "type": "string", "format": "uri", "pattern": "^https?://" },
            "scrape_at": { "type": "string", "enum": ["start", "end", "both"] },
            "timeout_ms": { "type": "integer", "minimum": 1, "default": 2000 }
          }
        },
        "traces": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string", "format": "uri", "pattern": "^https?://" },
            "query": { "type": "string" },
            "timeout_ms": { "type": "integer", "minimum": 1, "default": 2000 }
          }
        },
        "logs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "source": { "type": "string", "enum": ["http", "file"] },
            "endpoint": { "type": "string", "format": "uri", "pattern": "^https?://" },
            "file_path": { "type": "string" },
            "format": { "type": "string", "enum": ["jsonl", "ndjson"], "default": "jsonl" },
            "max_lines": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 500 }
          },
          "allOf": [
            {
              "if": {
                "properties": { "enabled": { "const": true }, "source": { "const": "http" } },
                "required": ["enabled", "source"]
              },
              "then": { "required": ["endpoint"] }
            },
            {
              "if": {
                "properties": { "enabled": { "const": true }, "source": { "const": "file" } },
                "required": ["enabled", "source"]
              },
              "then": { "required": ["file_path"] }
            }
          ]
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headers": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["authorization", "cookie", "set-cookie", "x-api-key"]
        },
        "json_paths": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "mask": { "type": "string", "default": "***REDACTED***" },
        "max_body_preview_bytes": { "type": "integer", "minimum": 1, "default": 4096 },
        "max_samples": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
      }
    }
  },
  "$defs": {
    "seed": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "pattern": "^[0-9]{1,20}$" }
      ]
    },
    "auth": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": { "type": { "const": "none" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "bearer_token_env"],
          "properties": {
            "type": { "const": "bearer" },
            "bearer_token_env": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "username_env", "password_env"],
          "properties": {
            "type": { "const": "basic" },
            "username_env": { "type": "string", "minLength": 1 },
            "password_env": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "api_key_env", "in", "name"],
          "properties": {
            "type": { "const": "api_key" },
            "api_key_env": { "type": "string", "minLength": 1 },
            "in": { "type": "string", "enum": ["header", "query"] },
            "name": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "requestSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "method", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
        "path": { "type": "string", "pattern": "^/" },
        "query": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {}
        },
        "body": { "type": "string" },
        "json_body": { "type": ["object", "array", "string", "number", "boolean", "null"] },
        "timeout_ms": { "type": "integer", "minimum": 1, "default": 5000 },
        "weight": { "type": "integer", "minimum": 1, "default": 1 },
        "idempotency_key": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        { "required": ["body"], "not": { "required": ["json_body"] } },
        { "required": ["json_body"], "not": { "required": ["body"] } }
      ]
    },
    "latency": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": { "mode": { "const": "none" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "ms"],
          "properties": {
            "mode": { "const": "fixed" },
            "ms": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "min_ms", "max_ms"],
          "properties": {
            "mode": { "const": "uniform" },
            "min_ms": { "type": "integer", "minimum": 0 },
            "max_ms": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "flapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "period_requests": { "type": "integer", "minimum": 1 },
        "down_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "behavior": { "type": "string", "const": "abort" }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": { "required": ["period_requests", "down_ratio", "behavior"] }
        }
      ]
    },
    "payloadDrift": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "allowed_mutations": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["json_set", "json_remove", "json_swap"] }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": { "required": ["rate", "allowed_mutations"] }
        }
      ]
    },
    "invariant": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": { "type": { "const": "no_5xx_allowed" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "max"],
          "properties": {
            "type": { "const": "max_4xx_rate" },
            "max": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "status", "max"],
          "properties": {
            "type": { "const": "status_code_rate" },
            "status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "max": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "request_id"],
          "properties": {
            "type": { "const": "idempotent_key_identical_response" },
            "request_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" }
          }
        }
      ]
    }
  }
}
