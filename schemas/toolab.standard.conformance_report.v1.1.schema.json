{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/toolab.standard.conformance_report.v1.1.schema.json",
  "title": "Toolab Standard Conformance Report v1.1",
  "description": "Reusable conformance report for any API implementing Toolab Standard v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "standard_version",
    "target",
    "generated_at",
    "overall",
    "checks"
  ],
  "properties": {
    "standard_version": {
      "type": "string",
      "const": "1.1"
    },
    "adapter_version": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_url"
      ],
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri"
        },
        "app_name": {
          "type": "string",
          "minLength": 1
        },
        "app_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "overall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "partial"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "declared": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "validated": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "missing_endpoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "capability": {
            "type": "string"
          },
          "endpoint": {
            "type": "string",
            "pattern": "^/|^https?://"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          },
          "message": {
            "type": "string"
          },
          "schema_id": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "profile_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "report_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
