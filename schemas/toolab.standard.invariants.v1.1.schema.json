{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/toolab.standard.invariants.v1.1.schema.json",
  "title": "Toolab Standard Invariants v1.1",
  "description": "Schema for GET /_toolab/invariants",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "invariants"
  ],
  "properties": {
    "invariants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/invariant"
      }
    }
  },
  "$defs": {
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "no_5xx_allowed",
            "max_4xx_rate",
            "status_code_rate",
            "idempotent_key_identical_response",
            "custom"
          ]
        },
        "description": {
          "type": "string"
        },
        "max": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "max_4xx_rate"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "max"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "status_code_rate"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "status",
              "max"
            ]
          }
        }
      ]
    }
  }
}
