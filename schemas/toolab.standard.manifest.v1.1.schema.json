{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/toolab.standard.manifest.v1.1.schema.json",
  "title": "Toolab Standard Manifest v1.1",
  "description": "Schema for GET /_toolab/manifest in Toolab Standard v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapter_version",
    "standard_version",
    "app_name",
    "app_version",
    "capabilities"
  ],
  "properties": {
    "adapter_version": {
      "type": "string",
      "const": "1"
    },
    "standard_version": {
      "type": "string",
      "const": "1.1"
    },
    "app_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "app_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "state.fingerprint",
          "state.snapshot",
          "state.restore",
          "state.reset",
          "seed",
          "metrics",
          "traces",
        "logs",
          "profile",
          "schema",
          "openapi",
          "suggested_flows",
          "invariants",
          "limits",
          "environment"
        ]
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openapi_url": {
          "type": "string",
          "format": "uri"
        },
        "schema_url": {
          "type": "string",
          "format": "uri"
        },
        "profile_url": {
          "type": "string",
          "format": "uri"
        },
        "suggested_flows_url": {
          "type": "string",
          "format": "uri"
        },
        "invariants_url": {
          "type": "string",
          "format": "uri"
        },
        "limits_url": {
          "type": "string",
          "format": "uri"
        },
        "environment_url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
