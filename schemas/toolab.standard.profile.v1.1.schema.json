{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/toolab.standard.profile.v1.1.schema.json",
  "title": "Toolab Standard Profile v1.1",
  "description": "Schema for GET /_toolab/profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "standard_version",
    "profile_version"
  ],
  "properties": {
    "standard_version": {
      "type": "string",
      "const": "1.1"
    },
    "profile_version": {
      "type": "string",
      "pattern": "^1(\\.[0-9]+)?$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "manifest": {
      "$ref": "./toolab.standard.manifest.v1.1.schema.json"
    },
    "schema": {
      "$ref": "./toolab.standard.schema.v1.1.schema.json"
    },
    "suggested_flows": {
      "$ref": "./toolab.standard.suggested_flows.v1.1.schema.json"
    },
    "invariants": {
      "$ref": "./toolab.standard.invariants.v1.1.schema.json"
    },
    "limits": {
      "$ref": "./toolab.standard.limits.v1.1.schema.json"
    },
    "environment": {
      "$ref": "./toolab.standard.environment.v1.1.schema.json"
    },
    "openapi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^3(\\.[0-9]+){1,2}$"
        },
        "etag": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "suggested_flows_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "invariants_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "limits_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "environment_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "openapi_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "oneOf": [
    {
      "required": [
        "schema"
      ]
    },
    {
      "required": [
        "suggested_flows"
      ]
    },
    {
      "required": [
        "invariants"
      ]
    },
    {
      "required": [
        "limits"
      ]
    },
    {
      "required": [
        "environment"
      ]
    },
    {
      "required": [
        "openapi"
      ]
    }
  ]
}
