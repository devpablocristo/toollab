{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toolab.dev/schemas/toolab.standard.schema.v1.1.schema.json",
  "title": "Toolab Standard Schema Capability v1.1",
  "description": "Schema for GET /_toolab/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "database",
    "entities"
  ],
  "properties": {
    "database": {
      "$ref": "#/$defs/database"
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "operation_effects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operation_effect"
      }
    }
  },
  "$defs": {
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._+-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "schema_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "table",
        "columns"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "table": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/column"
          }
        },
        "estimated_row_count_hint": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "nullable"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "nullable": {
          "type": "boolean"
        },
        "pk": {
          "type": "boolean"
        },
        "fk": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operation_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "effect",
        "idempotent"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "HEAD",
            "OPTIONS"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "effect": {
          "type": "string",
          "enum": [
            "read",
            "insert",
            "update",
            "delete"
          ]
        },
        "entity": {
          "type": [
            "string",
            "null"
          ]
        },
        "idempotent": {
          "type": "boolean"
        }
      }
    }
  }
}
