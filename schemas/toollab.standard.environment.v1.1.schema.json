{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toollab.dev/schemas/toollab.standard.environment.v1.1.schema.json",
  "title": "Toollab Standard Environment v1.1",
  "description": "Schema for GET /_toollab/environment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "read_only",
    "features"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "read_only": {
      "type": "boolean"
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "git_sha": {
          "type": "string",
          "minLength": 7
        },
        "deployed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
