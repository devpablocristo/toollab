{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toollab.dev/schemas/toollab.standard.error.v1.1.schema.json",
  "title": "Toollab Standard Error Envelope v1.1",
  "description": "Error payload schema for /_toollab/* endpoints",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error",
    "message"
  ],
  "properties": {
    "error": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9._-]+$"
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  }
}
