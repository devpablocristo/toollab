{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toollab.dev/schemas/toollab.error.v1.schema.json",
  "title": "Toollab Error Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error",
    "message"
  ],
  "properties": {
    "error": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "hint": {
      "type": "string"
    }
  }
}
