{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toollab.dev/schemas/toollab.standard.limits.v1.1.schema.json",
  "title": "Toollab Standard Limits v1.1",
  "description": "Schema for GET /_toollab/limits",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests_per_second"
      ],
      "properties": {
        "requests_per_second": {
          "type": "number",
          "minimum": 0
        },
        "burst": {
          "type": "integer",
          "minimum": 0
        },
        "window_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "quotas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "number",
            "minimum": 0
          },
          "period": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_default_ms": {
          "type": "integer",
          "minimum": 1
        },
        "request_max_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_inflight": {
          "type": "integer",
          "minimum": 1
        },
        "max_queue": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_request_body_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_response_body_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_logs_lines": {
          "type": "integer",
          "minimum": 1
        },
        "max_traces_spans": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
